{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/backup/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
